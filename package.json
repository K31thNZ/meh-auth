{
  "name": "meh-auth",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev":       "NODE_ENV=development tsx server/index.ts",
    "build":     "esbuild server/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:pg-native --external:cpu-features --external:passport-yandex --external:connect-pg-simple",
    "start":     "NODE_ENV=production node dist/index.cjs",
    "db:push":   "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "connect-pg-simple":       "^10.0.0",
    "cors":                    "^2.8.5",
    "drizzle-orm":             "^0.39.3",
    "esbuild":                 "^0.25.0",
    "express":                 "^5.0.1",
    "express-session":         "^1.19.0",
    "passport":                "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local":          "^1.0.0",
    "passport-yandex":         "0.0.5",
    "pg":                      "^8.16.3",
    "tsx":                     "^4.20.5",
    "zod":                     "^3.24.2"
  },
  "devDependencies": {
    "@types/connect-pg-simple":       "^7.0.3",
    "@types/cors":                    "^2.8.17",
    "@types/express":                 "^5.0.0",
    "@types/express-session":         "^1.18.2",
    "@types/node":                    "20.19.27",
    "@types/passport":                "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-local":          "^1.0.38",
    "drizzle-kit":                    "^0.31.8",
    "typescript":                     "5.6.3"
  }
}}
